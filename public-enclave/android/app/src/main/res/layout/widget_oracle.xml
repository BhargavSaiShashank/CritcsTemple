<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <ImageView
        android:id="@+id/widget_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_launcher_foreground"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:contentDescription="Oracle Icon" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="The Oracle's Eye"
        android:textColor="@color/colorAccent"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_toEndOf="@id/widget_icon"
        android:layout_marginStart="8dp"
        android:layout_alignTop="@id/widget_icon" />

    <TextView
        android:id="@+id/widget_movie_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Loading Prophecy..."
        android:textColor="@color/textPrimary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_below="@id/widget_icon"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/widget_movie_year"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sync Required"
        android:textColor="@color/textSecondary"
        android:textSize="11sp"
        android:layout_below="@id/widget_movie_title"
        android:layout_marginTop="2dp" />

    <TextView
        android:id="@+id/widget_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TAP TO SEAL VERDICT"
        android:textColor="@color/colorAccent"
        android:textSize="9sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true" />
</RelativeLayout>
