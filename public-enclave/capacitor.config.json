{
  "appId": "com.sanctuary.app",
  "appName": "Critic's Temple",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0c0c0c",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0c0c0c"
    },
    "CapacitorHttp": {
      "enabled": true
    },
    "CapacitorUpdater": {
      "autoUpdate": true,
      "statsUrl": "https://api.capgo.app/stats",
      "defaultChannel": "production"
    }
  },
  "server": {
    "androidScheme": "http"
  }
}